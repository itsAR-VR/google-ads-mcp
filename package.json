{
  "name": "google-ads-mcp",
  "version": "0.1.0",
  "description": "Open-source MCP server for Google Ads reads via GAQL and mutations via Google Ads API",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint . --ext .ts",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "google-ads",
    "gaql",
    "google-ads-api",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "private": "false",
  "bin": {
    "google-ads-mcp": "./dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/itsAR-VR/google-ads-mcp.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "google-ads-api": "^23.0.0",
    "google-auth-library": "^10.6.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
